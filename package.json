{
	"name": "@roastery-capsules/response-mapper",
	"description": "Elysia plugin that automatically maps entity responses to DTOs for the Roastery CMS ecosystem.",
	"version": "0.0.1",
	"type": "module",
	"author": {
		"name": "Alan Reis",
		"email": "alanreisanjo@gmail.com",
		"url": "https://github.com/Hoyasumii"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/roastery-cms/capsules-api-error-handler"
	},
	"license": "MIT",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"typesVersions": {
		"*": {
			"*": [
				"./dist/*/index.d.ts"
			]
		}
	},
	"keywords": [
		"roastery",
		"elysia",
		"elysia-plugin",
		"response-mapper",
		"entity",
		"dto",
		"mapper",
		"caffeine"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./*": {
			"types": "./dist/*/index.d.ts",
			"import": "./dist/*/index.js",
			"require": "./dist/*/index.cjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "biome check --fix && tsup 'src/**/index.ts' --format cjs,esm --dts --tsconfig tsconfig.build.json --clean",
		"test:unit": "bun test --env-file=.env.testing",
		"test:coverage": "bun test --env-file=.env.testing --coverage",
		"setup": "bun run build && bun link",
		"prepare": "husky || true",
		"knip": "knip"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.4.1",
		"@commitlint/config-conventional": "^20.4.1",
		"husky": "^9.1.7",
		"knip": "^5.85.0"
	},
	"peerDependencies": {
		"@roastery/barista": "^0.0.5",
		"@roastery/beans": "^0.0.2",
		"@sinclair/typebox": ">= 0.34.0 < 1",
		"@types/bun": "latest",
		"tsup": "^8.5.1",
		"typescript": "^5"
	},
	"dependencies": {}
}
